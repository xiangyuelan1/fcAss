# A股预测训练平台 - 环境变量配置示例
# 复制此文件为 .env 并修改相应值

# 应用配置
APP_NAME=A股预测训练平台
APP_VERSION=1.0.0
DEBUG=False

# 服务器配置
HOST=0.0.0.0
PORT=8000

# 数据库配置
DATABASE_URL=sqlite:///./a_stock_trainer.db
# PostgreSQL示例:
# DATABASE_URL=postgresql://user:password@localhost:5432/astock_trainer

# 数据存储路径
DATA_DIR=./data
MODEL_DIR=./models
LOG_DIR=./logs

# 安全配置 (重要: 生产环境必须修改!)
SECRET_KEY=your-super-secret-key-change-this-in-production
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=10080

# Redis配置 (可选，用于缓存)
# REDIS_URL=redis://localhost:6379/0

# akshare超时配置
AKSHARE_TIMEOUT=30
MAX_RETRY=3
